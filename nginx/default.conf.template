server {
    listen 80;
    server_name localhost;

    ${AUTH_CONFIG}

    # Global streaming and proxy rules for all routes
    proxy_http_version 1.1;             # Required for persistent LLM streams
    proxy_set_header Connection "";     # Prevents header closing signals
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;

    # FIX: Crucial SSE variables to prevent Nginx from caching tokens
    proxy_buffering off;                # Disables Nginx buffering; passes tokens instantly
    proxy_cache off;                    # Bypasses local intermediate caches
    chunked_transfer_encoding on;       # Forces HTTP chunking for continuous generation

    location /v1/chat/completions {
        proxy_pass http://gemma4_backend;
        proxy_read_timeout 600s;
        proxy_send_timeout 600s;
    }

    location /health {
        proxy_pass http://gemma4_backend/health;
        proxy_read_timeout 10s;
    }

    # --- RAW PROMETHEUS TELEMETRY STREAM (RTX 5090) ---
    location /metrics {
        proxy_pass http://gemma4_backend/metrics;
        proxy_read_timeout 15s;
    }

    location /v1/embeddings {
        proxy_pass http://embedding_backend;
        proxy_read_timeout 300s;        # Higher timeout for large embedded docs
    }

    location /v1/rerank {
        proxy_pass http://reranker_backend;
        proxy_read_timeout 300s;        # Higher timeout for large embedded docs
    }

    # --- FIX: ISOLATE LLAMA CHAT UI UNDER a PROTECTED PREFIX ---
    # Moving this ensures /models and /props do not override Grafana's API paths
    location /llama/ {
        proxy_pass http://gemma4_backend/;
        proxy_read_timeout 30s;
    }
}